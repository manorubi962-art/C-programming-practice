#include<stdio.h>
#include<string.h>
struct student{
	int roll;
	float marks;
	char grade;
};
int main(){
	struct student s1={1234,78.9,'C'
	};
	struct student *p=&s1;
	printf("marks: %f\n", p->marks);
	return 0;
}
-----------call by value---------------
#include<stdio.h>
#include<string.h>
struct student{
	int roll;
	float marks;
	char grade;
};
void info(struct student s1){
	printf("enter the num \n");
	printf("enter the roll %d\n", s1.roll);
	printf("enter the roll %.1f\n", s1.marks);
	printf("enter the roll %c\n", s1.grade);
};
int main(){
	struct student s1={123,78.9,'B'};
	info(s1);
	return 0;
}
